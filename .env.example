# Token do bot do Telegram (obtido com @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# (Opcional) IDs de usuarios autorizados a iniciar onboarding/admin no Telegram sem link.
# Aceita valores separados por virgula, ponto e virgula ou quebra de linha.
# Quando vazio, o fallback padrao continua: qualquer usuario novo pode fazer o bootstrap inicial.
# TELEGRAM_ADMIN_IDS=123456789,987654321

# Chave da API OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sua_chave_aqui

# (Opcional) Modelos open-source com fallback — separados por vírgula.
# Se não definido, usa os padrões abaixo:
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
#   google/gemma-3-12b-it:free
#   qwen/qwen-2.5-7b-instruct:free
# OPENROUTER_MODELS=meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free

# (Opcional) Modelo de embeddings local (sentence-transformers)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# WhatsApp Web via QR code (opcional)
# Habilite em 1 para subir o bridge local junto com o app.
WHATSAPP_WEB_ENABLED=0
# Em Linux headless/servidor sem DISPLAY, use 0 e rode o bridge manualmente.
WHATSAPP_WEB_AUTO_LAUNCH=1

# Endereco local do bridge Python consumido pelo terminal do WhatsApp.
WHATSAPP_WEB_BRIDGE_HOST=127.0.0.1
WHATSAPP_WEB_BRIDGE_PORT=8010
WHATSAPP_WEB_BRIDGE_PATH=/bridge/whatsapp/message

# Token local para o bridge HTTP (opcional, mas recomendado).
WHATSAPP_WEB_BRIDGE_TOKEN=troque-por-um-token-local

# Endereco do endpoint de status do cliente Node/WhatsApp.
WHATSAPP_WEB_CLIENT_HOST=127.0.0.1
WHATSAPP_WEB_CLIENT_PORT=8011
WHATSAPP_WEB_CLIENT_HEALTH_PATH=/health

# Identificador da sessao e pasta persistente do WhatsApp Web.
WHATSAPP_WEB_CLIENT_ID=atendimento-bot
WHATSAPP_WEB_SESSION_DIR=data/whatsapp-web-session
WHATSAPP_WEB_CLIENT_COMMAND=npm run whatsapp:bridge
WHATSAPP_WEB_LAUNCH_TIMEOUT_SECONDS=15

# (Opcional) Lista de numeros autorizados a iniciar o onboarding/admin sem link.
# Aceita valores separados por virgula, ponto e virgula ou quebra de linha.
# Quando vazio, o fallback padrao continua: o numero que leu o QR pode fazer o bootstrap inicial.
# WHATSAPP_ADMIN_NUMBERS=5511999999999,5511888888888

# Se houver mais de uma empresa no banco, defina qual sera atendida no WhatsApp.
# WHATSAPP_DEFAULT_COMPANY_ID=1
# WHATSAPP_DEFAULT_COMPANY_LINK_TOKEN=abc123
