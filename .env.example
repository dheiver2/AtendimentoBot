# Token do bot do Telegram (obtido com @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Chave da API Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=sua_chave_aqui

# Modelo de geração usado pelo agente
GOOGLE_GENERATION_MODEL=gemini-2.5-flash

# Modelo de embeddings usado na indexação dos PDFs
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
